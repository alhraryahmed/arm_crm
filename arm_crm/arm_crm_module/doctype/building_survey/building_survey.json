   "label": "\u0645\u0644\u0627\u062d\u0638\u0627\u062a \u0645\u0647\u0645\u0629",
   "options": "<div style=\"direction:rtl;\n  font-family:Arial;\n  font-size:14px;\n  line-height:2;\n  background:#fff8db;\n  border:1px solid #f3e6a6;\n  border-radius:14px;\n  padding:18px 20px;\n  color:#1f2937;\">\n\n<!-- \u0627\u0644\u0639\u0646\u0648\u0627\u0646 -->\n<div style=\"font-size:16px; font-weight:600; margin-bottom:12px;\">\n\ud83d\udcdd \u0645\u0644\u0627\u062d\u0638\u0627\u062a \u0645\u0647\u0645\u0629\n</div>\n\n<!-- \u0627\u0644\u0646\u0642\u0627\u0637 -->\n<div style=\"margin-bottom:10px;\">\n\ud83d\udd39 \u0627\u0644\u0633\u0624\u0627\u0644 \u0641\u064a \u0647\u0630\u0627 \u0627\u0644\u0627\u0633\u062a\u0628\u064a\u0627\u0646 \u0633\u064a\u0633\u0627\u0639\u062f\u0646\u0627 \u0641\u064a \u0627\u0644\u0648\u0635\u0648\u0644 \u0625\u0644\u0649 \u062a\u0635\u0645\u064a\u0645 \u0645\u0644\u0627\u0626\u0645 \u0644\u0627\u062d\u062a\u064a\u0627\u062c\u0627\u062a \u0627\u0644\u0632\u0628\u0648\u0646.\n</div>\n\n<div style=\"margin-bottom:10px;\">\n\ud83d\udd39 \u064a\u0645\u0643\u0646\u0643 \u0627\u062e\u062a\u064a\u0627\u0631 \u0623\u0643\u062b\u0631 \u0645\u0646 \u0625\u062c\u0627\u0628\u0629 \u0641\u064a \u062d\u0627\u0644 \u0648\u062c\u0648\u062f \u0623\u0643\u062b\u0631 \u0645\u0646 \u062e\u064a\u0627\u0631 \u0645\u0645\u0643\u0646.\n</div>\n\n<div style=\"margin-bottom:10px;\">\n\ud83d\udd39 \u064a\u0631\u062c\u0649 \u0627\u0644\u0625\u062c\u0627\u0628\u0629 \u0639\u0646 \u062c\u0645\u064a\u0639 \u0627\u0644\u0623\u0633\u0626\u0644\u0629\u060c \u0648\u0641\u064a \u062d\u0627\u0644 \u0639\u062f\u0645 \u0627\u0644\u062a\u0623\u0643\u062f \u0645\u0646 \u0627\u0644\u0625\u062c\u0627\u0628\u0629 \u064a\u0631\u062c\u0649 \u0645\u0646\u0627\u0642\u0634\u0629 \u0630\u0644\u0643 \u0645\u0639 \u0627\u0644\u0645\u0635\u0645\u0645 \u0644\u0636\u0645\u0627\u0646 \u0627\u0644\u0627\u0633\u062a\u0641\u0627\u062f\u0629 \u0645\u0646 \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a \u0628\u0634\u0643\u0644 \u0635\u062d\u064a\u062d.\n</div>\n\n<div style=\"margin-bottom:10px;\">\n\ud83d\udd39 \u0641\u064a \u062d\u0627\u0644 \u0639\u062f\u0645 \u062a\u0642\u064a\u064a\u062f \u0627\u0644\u0632\u0628\u0648\u0646 \u0644\u062e\u064a\u0627\u0631 \u0645\u0639\u064a\u0646\u060c \u064a\u0631\u062c\u0649 \u0639\u062f\u0645 \u0627\u0644\u0625\u062c\u0627\u0628\u0629 \u0639\u0644\u0649 \u0627\u0644\u0633\u0624\u0627\u0644.\n</div>\n\n</div>"

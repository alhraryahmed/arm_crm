   "description": "<div style=\"position:relative; display:inline-block;\">\r\n\r\n    <!-- \u0632\u0631 \u0627\u0644\u0627\u0633\u062a\u0641\u0647\u0627\u0645 -->\r\n    <span onclick=\"this.nextElementSibling.classList.toggle('show')\" \r\n    style=\"cursor:pointer; font-size:16px; background:#3b82f6; color:#fff; padding:4px 8px; border-radius:50%;\">\r\n\r\n    </span>\r\n\r\n    <!-- \u0627\u0644\u0633\u062d\u0627\u0628\u0629 -->\r\n    <div class=\"bubble\">\r\n        \u0639\u0631\u0636 \u0627\u0644\u0623\u0633\u0639\u0627\u0631: \u0625\u0646\u0634\u0627\u0621 \u0639\u0631\u0648\u0636<br>\r\n        \u0623\u0645\u0631 \u0627\u0644\u062a\u0639\u0627\u0642\u062f: \u062a\u0623\u0643\u064a\u062f \u0627\u0644\u0637\u0644\u0628<br>\r\n        \u0641\u0627\u062a\u0648\u0631\u0629 \u0645\u0634\u0631\u0648\u0639: \u062a\u062d\u0635\u064a\u0644 \u0627\u0644\u062f\u0641\u0639\r\n    </div>\r\n\r\n</div>\r\n\r\n<style>\r\n.bubble {\r\n    position:absolute;\r\n    top:30px;\r\n    right:0;\r\n    background:#0f172a;\r\n    color:#fff;\r\n    padding:10px;\r\n    border-radius:8px;\r\n    width:200px;\r\n    font-size:12px;\r\n    line-height:1.5;\r\n\r\n    opacity:0;\r\n    transform:translateY(-8px);\r\n    transition:0.3s;\r\n    pointer-events:none;\r\n}\r\n\r\n/* \u0633\u0647\u0645 */\r\n.bubble::after {\r\n    content:\"\";\r\n    position:absolute;\r\n    top:-5px;\r\n    right:10px;\r\n    width:8px;\r\n    height:8px;\r\n    background:#0f172a;\r\n    transform:rotate(45deg);\r\n}\r\n\r\n.bubble.show {\r\n    opacity:1;\r\n    transform:translateY(0);\r\n    pointer-events:auto;\r\n}\r\n</style>",

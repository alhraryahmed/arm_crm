 "custom_css": "/* =========================\r\n   \ud83c\udf10 ARM SURVEY MODERN UI (Dark/Glass Theme)\r\n   ========================= */\r\n\r\n/* 1. \u0625\u0639\u062f\u0627\u062f\u0627\u062a \u0623\u0633\u0627\u0633\u064a\u0629 \u0644\u0636\u0645\u0627\u0646 \u0639\u062f\u0645 \u062e\u0631\u0648\u062c \u0627\u0644\u0639\u0646\u0627\u0635\u0631 \u0639\u0646 \u0627\u0644\u062d\u0627\u0648\u064a\u0627\u062a */\r\n*, *::before, *::after {\r\n    box-sizing: border-box;\r\n}\r\n\r\n/* 2. \u0627\u0644\u062e\u0644\u0641\u064a\u0629 \u0627\u0644\u0639\u0627\u0645\u0629 */\r\nbody {\r\n    background: linear-gradient(135deg, #0f172a, #1e293b);\r\n    font-family: \"Cairo\", system-ui, -apple-system, sans-serif; /* \u0625\u0636\u0627\u0641\u0629 \u062e\u0637\u0648\u0637 \u0628\u062f\u064a\u0644\u0629 */\r\n    direction: rtl;\r\n    min-height: 100vh; /* \u0644\u0636\u0645\u0627\u0646 \u062a\u063a\u0637\u064a\u0629 \u0627\u0644\u0634\u0627\u0634\u0629 \u0628\u0627\u0644\u0643\u0627\u0645\u0644 */\r\n    margin: 0;\r\n    padding: 20px 0; /* \u0645\u0633\u0627\u0641\u0629 \u0639\u0644\u0648\u064a\u0629 \u0648\u0633\u0641\u0644\u064a\u0629 \u0644\u0644\u0645\u0648\u0628\u0627\u064a\u0644 */\r\n    color: #f8fafc; /* \u0644\u0648\u0646 \u0627\u0644\u0646\u0635 \u0627\u0644\u0627\u0641\u062a\u0631\u0627\u0636\u064a */\r\n}\r\n\r\n/* 3. \u0627\u0644\u062d\u0627\u0648\u064a\u0629 \u0627\u0644\u0631\u0626\u064a\u0633\u064a\u0629 */\r\n.web-form-container {\r\n    max-width: 850px;\r\n    width: 90%; /* \u062a\u062c\u0627\u0648\u0628 \u0623\u0641\u0636\u0644 \u0645\u0639 \u0627\u0644\u0634\u0627\u0634\u0627\u062a \u0627\u0644\u0635\u063a\u064a\u0631\u0629 */\r\n    margin: 0 auto;\r\n}\r\n\r\n/* 4. \u0627\u0644\u0639\u0646\u0648\u0627\u0646 \u0627\u0644\u0631\u0626\u064a\u0633\u064a */\r\n.web-form-container h1 {\r\n    text-align: center;\r\n    font-size: clamp(22px, 4vw, 32px); /* \u062e\u0637 \u064a\u062a\u063a\u064a\u0631 \u062d\u062c\u0645\u0647 \u0628\u0645\u0631\u0648\u0646\u0629 \u062d\u0633\u0628 \u0627\u0644\u0634\u0627\u0634\u0629 */\r\n    color: #ffffff;\r\n    margin-bottom: 30px;\r\n    font-weight: 700;\r\n    letter-spacing: 0.5px;\r\n    text-shadow: 0 2px 4px rgba(0,0,0,0.3); /* \u0625\u0628\u0631\u0627\u0632 \u0627\u0644\u0639\u0646\u0648\u0627\u0646 */\r\n}\r\n\r\n/* 5. \u0635\u0646\u062f\u0648\u0642 \u0627\u0644\u0627\u0633\u062a\u0628\u064a\u0627\u0646 (\u062a\u0623\u062b\u064a\u0631 \u0627\u0644\u0632\u062c\u0627\u062c \u0627\u0644\u0645\u062d\u0633\u0646) */\r\n.form-layout {\r\n    background: rgba(255, 255, 255, 0.05); /* \u062a\u0642\u0644\u064a\u0644 \u0627\u0644\u0634\u0641\u0627\u0641\u064a\u0629 \u0642\u0644\u064a\u0644\u0627\u064b \u0644\u062a\u0628\u0627\u064a\u0646 \u0623\u0641\u0636\u0644 */\r\n    backdrop-filter: blur(16px);\r\n    -webkit-backdrop-filter: blur(16px); /* \u0644\u062f\u0639\u0645 \u0633\u0641\u0627\u0631\u064a */\r\n    border-radius: 20px;\r\n    padding: 40px;\r\n    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5); /* \u0638\u0644 \u0623\u0643\u062b\u0631 \u0648\u0627\u0642\u0639\u064a\u0629 */\r\n    border: 1px solid rgba(255, 255, 255, 0.08);\r\n}\r\n\r\n/* 6. \u0645\u0633\u0627\u0641\u0627\u062a \u0627\u0644\u062d\u0642\u0648\u0644 */\r\n[data-fieldname] {\r\n    margin-bottom: 22px;\r\n}\r\n\r\n/* 7. \u0627\u0644\u0646\u0635\u0648\u0635 \u0627\u0644\u062a\u0648\u0636\u064a\u062d\u064a\u0629 (Labels) */\r\n[data-fieldname] label {\r\n    color: #cbd5e1; /* \u0644\u0648\u0646 \u0623\u0641\u062a\u062d \u0642\u0644\u064a\u0644\u0627\u064b \u0644\u0633\u0647\u0648\u0644\u0629 \u0627\u0644\u0642\u0631\u0627\u0621\u0629 */\r\n    font-weight: 600;\r\n    margin-bottom: 8px;\r\n    display: inline-block;\r\n    font-size: 15px;\r\n    letter-spacing: 0.3px;\r\n}\r\n\r\n/* 8. \u062d\u0642\u0648\u0644 \u0627\u0644\u0625\u062f\u062e\u0627\u0644 \u0648\u0627\u0644\u0642\u0648\u0627\u0626\u0645 */\r\n[data-fieldname] select,\r\n[data-fieldname] input,\r\n[data-fieldname] textarea {\r\n    width: 100%;\r\n    padding: 14px 16px;\r\n    border-radius: 12px;\r\n    border: 1px solid rgba(255, 255, 255, 0.15);\r\n    background: rgba(15, 23, 42, 0.7);\r\n    color: #ffffff;\r\n    font-family: inherit;\r\n    font-size: 15px;\r\n    outline: none;\r\n    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); /* \u062d\u0631\u0643\u0629 \u0623\u0646\u0639\u0645 */\r\n}\r\n\r\n/* \u062a\u063a\u064a\u064a\u0631 \u0644\u0648\u0646 \u0627\u0644\u0646\u0635 \u0627\u0644\u0645\u0624\u0642\u062a (Placeholder) */\r\n[data-fieldname] input::placeholder,\r\n[data-fieldname] textarea::placeholder {\r\n    color: #64748b;\r\n}\r\n\r\n/* 9. \u062a\u0623\u062b\u064a\u0631\u0627\u062a \u0627\u0644\u062a\u0631\u0643\u064a\u0632 (Focus) \u0648\u0627\u0644\u0644\u0645\u0633 (Hover) */\r\n[data-fieldname] select:focus,\r\n[data-fieldname] input:focus,\r\n[data-fieldname] textarea:focus {\r\n    border-color: #38bdf8;\r\n    background: rgba(15, 23, 42, 0.9);\r\n    box-shadow: 0 0 0 4px rgba(56, 189, 248, 0.15);\r\n}\r\n\r\n[data-fieldname] select:hover,\r\n[data-fieldname] input:hover,\r\n[data-fieldname] textarea:hover {\r\n    border-color: rgba(255, 255, 255, 0.3);\r\n}\r\n\r\n/* 10. \u0632\u0631 \u0627\u0644\u0625\u0631\u0633\u0627\u0644 */\r\n.btn-primary {\r\n    background: linear-gradient(135deg, #0ea5e9, #4f46e5); /* \u0623\u0644\u0648\u0627\u0646 \u0623\u0643\u062b\u0631 \u062d\u064a\u0648\u064a\u0629 */\r\n    border: none;\r\n    padding: 14px 28px;\r\n    border-radius: 12px;\r\n    font-weight: 700;\r\n    font-size: 16px;\r\n    color: white;\r\n    cursor: pointer;\r\n    width: 100%; /* \u062c\u0639\u0644 \u0627\u0644\u0632\u0631 \u0628\u0639\u0631\u0636 \u0627\u0644\u0646\u0645\u0648\u0630\u062c \u0628\u0627\u0644\u0643\u0627\u0645\u0644 - \u064a\u0645\u0643\u0646\u0643 \u0625\u0632\u0627\u0644\u062a\u0647\u0627 \u0625\u0646 \u0644\u0645 \u062a\u0631\u063a\u0628 \u0628\u0630\u0644\u0643 */\r\n    transition: all 0.3s ease;\r\n    box-shadow: 0 10px 20px -5px rgba(14, 165, 233, 0.4);\r\n    margin-top: 10px;\r\n}\r\n\r\n.btn-primary:hover {\r\n    transform: translateY(-3px);\r\n    box-shadow: 0 15px 25px -5px rgba(79, 70, 229, 0.5);\r\n    background: linear-gradient(135deg, #0284c7, #4338ca);\r\n}\r\n\r\n.btn-primary:active {\r\n    transform: translateY(0); /* \u062a\u0623\u062b\u064a\u0631 \u0627\u0644\u0636\u063a\u0637 \u0627\u0644\u062d\u0642\u064a\u0642\u064a */\r\n}\r\n\r\n/* 11. \u0642\u0633\u0645 \u0627\u0644\u0639\u0644\u0627\u0642\u0629 (relation_type) */\r\n[data-fieldname=\"relation_type\"] {\r\n    background: rgba(56, 189, 248, 0.05);\r\n    border: 1px solid rgba(56, 189, 248, 0.2);\r\n    padding: 16px;\r\n    border-radius: 14px;\r\n    transition: all 0.3s ease;\r\n}\r\n\r\n[data-fieldname=\"relation_type\"]:hover {\r\n    background: rgba(56, 189, 248, 0.08);\r\n    border-color: rgba(56, 189, 248, 0.4);\r\n}\r\n\r\n/* 12. \u0634\u0631\u064a\u0637 \u0627\u0644\u062a\u0645\u0631\u064a\u0631 (Scrollbar) */\r\n::-webkit-scrollbar {\r\n    width: 10px;\r\n}\r\n\r\n::-webkit-scrollbar-track {\r\n    background: #0f172a;\r\n}\r\n\r\n::-webkit-scrollbar-thumb {\r\n    background: #475569;\r\n    border-radius: 10px;\r\n    border: 2px solid #0f172a; /* \u0644\u0625\u0639\u0637\u0627\u0621 \u0645\u0633\u0627\u062d\u0629 \u0644\u0644\u0634\u0631\u064a\u0637 */\r\n}\r\n\r\n::-webkit-scrollbar-thumb:hover {\r\n    background: #38bdf8;\r\n}\r\n\r\n/* 13. \u0627\u0644\u062a\u062c\u0627\u0648\u0628 \u0645\u0639 \u0634\u0627\u0634\u0627\u062a \u0627\u0644\u062c\u0648\u0627\u0644 (Media Queries) */\r\n@media (max-width: 600px) {\r\n    .form-layout {\r\n        padding: 25px 20px;\r\n    }\r\n    \r\n    [data-fieldname] select,\r\n    [data-fieldname] input,\r\n    [data-fieldname] textarea {\r\n        padding: 12px;\r\n    }\r\n}",

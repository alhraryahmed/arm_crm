 "client_script": "/* =========================================\r\n   \ud83c\udf10 ARM MODERN SURVEY UI - JS SCRIPT\r\n   ========================================= */\r\n\r\ndocument.addEventListener(\"DOMContentLoaded\", function() {\r\n    // 1. \u062a\u062d\u062f\u064a\u062f \u0627\u0644\u0645\u062c\u0645\u0648\u0639\u0627\u062a \u0628\u0646\u0627\u0621\u064b \u0639\u0644\u0649 \u0627\u0644\u062d\u0642\u0648\u0644 \u0627\u0644\u0645\u0630\u0643\u0648\u0631\u0629 \u0641\u064a \u0627\u0644\u0640 CSS\r\n    const formSections = [\r\n        {\r\n            title: \"\ud83d\udc64 \u0645\u0639\u0644\u0648\u0645\u0627\u062a \u0627\u0644\u062a\u0648\u0627\u0635\u0644\",\r\n            fields: [\"full_name\", \"phone\", \"email\"]\r\n        },\r\n        {\r\n            title: \"\ud83c\udfe0 \u0627\u0644\u0633\u0643\u0646 \u0627\u0644\u062d\u0627\u0644\u064a\",\r\n            fields: [\"current_residence\", \"city\"]\r\n        },\r\n        {\r\n            title: \"\ud83d\udc68\u200d\ud83d\udc69\u200d\ud83d\udc67 \u0645\u0639\u0644\u0648\u0645\u0627\u062a \u0627\u0644\u0623\u0633\u0631\u0629\",\r\n            fields: [\"size_family\", \"couples\", \"grandchildren\"]\r\n        },\r\n        {\r\n            title: \"\ud83c\udfd7\ufe0f \u0646\u0645\u0637 \u0627\u0644\u062d\u064a\u0627\u0629 \u0648\u0627\u0644\u0645\u0633\u0627\u062d\u0627\u062a\",\r\n            fields: [\"living_type\", \"kitchen_type\", \"dining_type\"]\r\n        },\r\n        {\r\n            title: \"\ud83d\udd17 \u062a\u0641\u0627\u0635\u064a\u0644 \u0625\u0636\u0627\u0641\u064a\u0629\",\r\n            fields: [\"relation_type\"] \r\n        }\r\n    ];\r\n\r\n    // \u0627\u0644\u0628\u062d\u062b \u0639\u0646 \u0627\u0644\u0646\u0645\u0648\u0630\u062c \u0627\u0644\u0623\u0633\u0627\u0633\u064a (Form)\r\n    const formContainer = document.querySelector('.web-form-container form') || document.querySelector('form');\r\n\r\n    if (formContainer) {\r\n        // \u0625\u0636\u0627\u0641\u0629 \u0627\u0644\u0643\u0644\u0627\u0633 \u0627\u0644\u0623\u0633\u0627\u0633\u064a \u0644\u0644\u062d\u0627\u0648\u064a\u0629 \u0625\u0630\u0627 \u0644\u0645 \u064a\u0643\u0646 \u0645\u0648\u062c\u0648\u062f\u0627\u064b\r\n        if (!formContainer.classList.contains('form-layout')) {\r\n            formContainer.classList.add('form-layout');\r\n        }\r\n\r\n        // 2. \u0625\u0646\u0634\u0627\u0621 \u0627\u0644\u0628\u0637\u0627\u0642\u0627\u062a \u0648\u0646\u0642\u0644 \u0627\u0644\u062d\u0642\u0648\u0644 \u0628\u062f\u0627\u062e\u0644\u0647\u0627\r\n        formSections.forEach(section => {\r\n            // \u062c\u0644\u0628 \u0627\u0644\u062d\u0642\u0648\u0644 \u0627\u0644\u0645\u0648\u062c\u0648\u062f\u0629 \u0641\u0639\u0644\u064a\u0627\u064b \u0641\u064a \u0627\u0644\u0635\u0641\u062d\u0629 \u0648\u062a\u062a\u0628\u0639 \u0647\u0630\u0647 \u0627\u0644\u0645\u062c\u0645\u0648\u0639\u0629\r\n            const existingFields = section.fields\r\n                .map(fieldName => document.querySelector(`[data-fieldname=\"${fieldName}\"]`))\r\n                .filter(el => el !== null);\r\n\r\n            // \u0625\u0630\u0627 \u0648\u062c\u062f\u0646\u0627 \u062d\u0642\u0648\u0644\u0627\u064b \u062a\u0627\u0628\u0639\u0629 \u0644\u0647\u0630\u0627 \u0627\u0644\u0642\u0633\u0645\u060c \u0646\u0642\u0648\u0645 \u0628\u0625\u0646\u0634\u0627\u0621 \u0628\u0637\u0627\u0642\u0629 \u0644\u0647\u0627\r\n            if (existingFields.length > 0) {\r\n                // \u0625\u0646\u0634\u0627\u0621 \u062d\u0627\u0648\u064a\u0629 \u0627\u0644\u0628\u0637\u0627\u0642\u0629 (Card)\r\n                const sectionCard = document.createElement('div');\r\n                sectionCard.className = 'section-card';\r\n\r\n                // \u0625\u0646\u0634\u0627\u0621 \u0639\u0646\u0648\u0627\u0646 \u0627\u0644\u0628\u0637\u0627\u0642\u0629 (Title)\r\n                const sectionTitle = document.createElement('div');\r\n                sectionTitle.className = 'section-title';\r\n                sectionTitle.innerText = section.title;\r\n                \r\n                // \u0625\u0636\u0627\u0641\u0629 \u0627\u0644\u0639\u0646\u0648\u0627\u0646 \u0625\u0644\u0649 \u0627\u0644\u0628\u0637\u0627\u0642\u0629\r\n                sectionCard.appendChild(sectionTitle);\r\n\r\n                // \u0625\u062f\u0631\u0627\u062c \u0627\u0644\u0628\u0637\u0627\u0642\u0629 \u0641\u064a \u0648\u0627\u062c\u0647\u0629 \u0627\u0644\u0645\u0633\u062a\u062e\u062f\u0645 (\u0642\u0628\u0644 \u0623\u0648\u0644 \u062d\u0642\u0644 \u0645\u0646 \u0647\u0630\u0647 \u0627\u0644\u0645\u062c\u0645\u0648\u0639\u0629)\r\n                existingFields[0].parentNode.insertBefore(sectionCard, existingFields[0]);\r\n\r\n                // \u0646\u0642\u0644 \u062c\u0645\u064a\u0639 \u0627\u0644\u062d\u0642\u0648\u0644 \u0627\u0644\u062e\u0627\u0635\u0629 \u0628\u0647\u0630\u0627 \u0627\u0644\u0642\u0633\u0645 \u0625\u0644\u0649 \u062f\u0627\u062e\u0644 \u0627\u0644\u0628\u0637\u0627\u0642\u0629 \u0627\u0644\u062c\u062f\u064a\u062f\u0629\r\n                existingFields.forEach(fieldElement => {\r\n                    sectionCard.appendChild(fieldElement);\r\n                });\r\n            }\r\n        });\r\n    }\r\n});",

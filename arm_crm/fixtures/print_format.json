  "css": "\r\n    .custom-survey-wrapper {\r\n        direction: rtl;\r\n        font-family: 'Tajawal', 'Cairo', 'Helvetica', sans-serif;\r\n        background-color: #fff;\r\n        padding: 0;\r\n        color: #333;\r\n    }\r\n    .survey-header-main {\r\n        background-color: #a8b2bc !important;\r\n        color: #2c3e50 !important;\r\n        padding: 15px;\r\n        font-size: 24px;\r\n        font-weight: bold;\r\n        text-align: right;\r\n        border-radius: 8px 8px 0 0;\r\n        margin-bottom: 20px;\r\n        -webkit-print-color-adjust: exact;\r\n        print-color-adjust: exact;\r\n    }\r\n    .survey-section {\r\n        border: 2px solid #5c6c7f !important;\r\n        border-radius: 8px;\r\n        margin-bottom: 20px;\r\n        page-break-inside: avoid;\r\n    }\r\n    .section-title {\r\n        background-color: #5c6c7f !important;\r\n        color: #fff !important;\r\n        padding: 10px 15px;\r\n        font-size: 18px;\r\n        font-weight: bold;\r\n        display: inline-block;\r\n        border-radius: 0 0 0 8px;\r\n        -webkit-print-color-adjust: exact;\r\n        print-color-adjust: exact;\r\n    }\r\n    .section-content {\r\n        padding: 15px;\r\n    }\r\n    .form-row-custom {\r\n        display: flex;\r\n        align-items: center;\r\n        margin-bottom: 12px;\r\n        border-bottom: 1px dashed #e2e8f0;\r\n        padding-bottom: 8px;\r\n    }\r\n    .form-row-custom label {\r\n        flex: 1;\r\n        font-weight: bold;\r\n        color: #2c3e50;\r\n        margin: 0;\r\n        font-size: 14px;\r\n    }\r\n    .val-text {\r\n        flex: 2;\r\n        border-bottom: 1px solid #333;\r\n        padding: 5px;\r\n        min-height: 20px;\r\n        font-weight: bold;\r\n        color: #000;\r\n    }\r\n    .checkbox-group {\r\n        display: flex;\r\n        flex-direction: column;\r\n        gap: 10px;\r\n    }\r\n    .checkbox-group.horizontal {\r\n        flex-direction: row;\r\n        gap: 20px;\r\n    }\r\n    .checkbox-custom {\r\n        display: flex;\r\n        align-items: center;\r\n        font-size: 14px;\r\n    }\r\n    .checkbox-custom input[type=\"radio\"], .checkbox-custom input[type=\"checkbox\"] {\r\n        margin-left: 8px;\r\n        width: 18px;\r\n        height: 18px;\r\n        accent-color: #5c6c7f;\r\n    }\r\n    .grid-main {\r\n        display: grid;\r\n        grid-template-columns: 1fr 1fr;\r\n        gap: 20px;\r\n    }\r\n    .grid-2-cols {\r\n        display: grid;\r\n        grid-template-columns: 1fr 1fr;\r\n        gap: 15px;\r\n    }\r\n    .map-container {\r\n        margin-top: 15px;\r\n        margin-bottom: 15px;\r\n        border: 1px solid #ccc;\r\n        border-radius: 8px;\r\n        padding: 40px 10px;\r\n        background: #fdfdfd;\r\n        text-align: center;\r\n        color: #999;\r\n    }\r\n",

  "html": "<style>\r\n    .custom-survey-wrapper {\r\n        direction: rtl;\r\n        font-family: 'Tajawal', 'Cairo', 'Helvetica', sans-serif;\r\n        background-color: #fff;\r\n        padding: 0;\r\n        color: #333;\r\n    }\r\n    .survey-header-main {\r\n        background-color: #a8b2bc !important;\r\n        color: #2c3e50 !important;\r\n        padding: 15px;\r\n        font-size: 24px;\r\n        font-weight: bold;\r\n        text-align: right;\r\n        border-radius: 8px 8px 0 0;\r\n        margin-bottom: 20px;\r\n        -webkit-print-color-adjust: exact;\r\n        print-color-adjust: exact;\r\n        color-adjust: exact;\r\n    }\r\n    .survey-section {\r\n        border: 2px solid #5c6c7f !important;\r\n        border-radius: 8px;\r\n        margin-bottom: 20px;\r\n        page-break-inside: avoid;\r\n        break-inside: avoid;\r\n    }\r\n    .section-title {\r\n        background-color: #5c6c7f !important;\r\n        color: #fff !important;\r\n        padding: 10px 15px;\r\n        font-size: 18px;\r\n        font-weight: bold;\r\n        display: inline-block;\r\n        border-radius: 0 0 0 8px;\r\n        -webkit-print-color-adjust: exact;\r\n        print-color-adjust: exact;\r\n        color-adjust: exact;\r\n    }\r\n    .section-content {\r\n        padding: 15px;\r\n    }\r\n    .form-row-custom {\r\n        display: flex;\r\n        align-items: center;\r\n        margin-bottom: 12px;\r\n        border-bottom: 1px dashed #e2e8f0;\r\n        padding-bottom: 8px;\r\n    }\r\n    .form-row-custom label {\r\n        flex: 1;\r\n        font-weight: bold;\r\n        color: #2c3e50;\r\n        margin: 0;\r\n        font-size: 14px;\r\n    }\r\n    .val-text {\r\n        flex: 2;\r\n        border-bottom: 1px solid #333;\r\n        padding: 5px;\r\n        min-height: 20px;\r\n        font-weight: bold;\r\n        color: #000;\r\n    }\r\n    .checkbox-group {\r\n        display: flex;\r\n        flex-direction: column;\r\n        gap: 10px;\r\n    }\r\n    .checkbox-group.horizontal {\r\n        flex-direction: row;\r\n        gap: 20px;\r\n    }\r\n    .checkbox-custom {\r\n        display: flex;\r\n        align-items: center;\r\n        font-size: 14px;\r\n    }\r\n    .checkbox-custom input[type=\"radio\"], .checkbox-custom input[type=\"checkbox\"] {\r\n        margin-left: 8px;\r\n        width: 18px;\r\n        height: 18px;\r\n        accent-color: #5c6c7f;\r\n    }\r\n    .grid-main {\r\n        display: grid;\r\n        grid-template-columns: 1fr 1fr;\r\n        gap: 20px;\r\n    }\r\n    .grid-2-cols {\r\n        display: grid;\r\n        grid-template-columns: 1fr 1fr;\r\n        gap: 15px;\r\n    }\r\n    .map-container {\r\n        margin-top: 15px;\r\n        margin-bottom: 15px;\r\n        border: 1px solid #ccc;\r\n        border-radius: 8px;\r\n        padding: 10px;\r\n        background: #fdfdfd;\r\n        text-align: center;\r\n    }\r\n</style>\r\n\r\n<div class=\"custom-survey-wrapper\">\r\n    \r\n    <div class=\"survey-header-main\">\r\n        نموذج استبيان مبنى سكني\r\n    </div>\r\n\r\n    <div class=\"grid-main\">\r\n        \r\n        <div>\r\n            <div class=\"survey-section\">\r\n                <div class=\"section-title\">معلومات خاصة بالمشروع</div>\r\n                <div class=\"section-content\">\r\n                    <div class=\"form-row-custom\">\r\n                        <label>أين يقع المشروع:</label>\r\n                        <div class=\"val-text\">{{ doc.project_location or '' }}</div>\r\n                    </div>\r\n\r\n                    <div class=\"map-container\">\r\n                        <label style=\"font-weight:bold; color:#2c3e50; display:block; margin-bottom:10px; text-align:right;\">تحديد الموقع في الخريطة:</label>\r\n                        \r\n                        <div id=\"map-render-area-{{ doc.name }}\">\r\n                            {% if not doc.gg %}\r\n                                <div style=\"padding: 30px; color: #999; font-size: 12px;\">\r\n                                    (لم يتم تحديد موقع على الخريطة لهذا المستند)\r\n                                </div>\r\n                            {% endif %}\r\n                        </div>\r\n                        \r\n                        {% if doc.gg %}\r\n                            <textarea id=\"hidden-map-data-{{ doc.name }}\" style=\"display:none;\">{{ doc.gg }}</textarea>\r\n                            <script>\r\n                                (function() {\r\n                                    try {\r\n                                        var docName = \"{{ doc.name }}\";\r\n                                        var dataStr = document.getElementById(\"hidden-map-data-\" + docName).value;\r\n                                        if (dataStr) {\r\n                                            var loc = JSON.parse(dataStr);\r\n                                            if (loc && loc.features && loc.features.length > 0) {\r\n                                                // استخراج خطوط الطول والعرض من ملف الـ JSON\r\n                                                var lon = loc.features[0].geometry.coordinates[0];\r\n                                                var lat = loc.features[0].geometry.coordinates[1];\r\n                                                \r\n                                                // حقن خريطة جوجل التفاعلية\r\n                                                var mapUrl = 'https://maps.google.com/maps?q=' + lat + ',' + lon + '&hl=ar&z=15&output=embed';\r\n                                                document.getElementById(\"map-render-area-\" + docName).innerHTML = '<iframe width=\"100%\" height=\"180\" frameborder=\"0\" style=\"border:0; border-radius: 8px;\" src=\"' + mapUrl + '\"></iframe>';\r\n                                            }\r\n                                        }\r\n                                    } catch(e) {\r\n                                        console.error(\"Map parsing error:\", e);\r\n                                    }\r\n                                })();\r\n                            </script>\r\n                        {% endif %}\r\n                    </div>\r\n                    \r\n                    <div class=\"form-row-custom\">\r\n                        <label>هل يوجد رسم كروكي للأرض؟</label>\r\n                        <div class=\"checkbox-group horizontal\">\r\n                            <label class=\"checkbox-custom\">\r\n                                <input type=\"radio\" {% if doc.has_sketch == 'نعم' %}checked{% endif %}> نعم\r\n                            </label>\r\n                            <label class=\"checkbox-custom\">\r\n                                <input type=\"radio\" {% if doc.has_sketch == 'لا' %}checked{% endif %}> لا\r\n                            </label>\r\n                        </div>\r\n                    </div>\r\n\r\n                    <div class=\"form-row-custom\">\r\n                        <label>هل يوجد نسخة إلكترونية (AutoCAD)؟</label>\r\n                        <div class=\"checkbox-group horizontal\">\r\n                            <label class=\"checkbox-custom\">\r\n                                <input type=\"radio\" {% if doc.has_autocad == 'نعم' %}checked{% endif %}> نعم\r\n                            </label>\r\n                            <label class=\"checkbox-custom\">\r\n                                <input type=\"radio\" {% if doc.has_autocad == 'لا' %}checked{% endif %}> لا\r\n                            </label>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n\r\n            <div class=\"survey-section\">\r\n                <div class=\"section-title\">معلومات خاصة بالزبون</div>\r\n                <div class=\"section-content\">\r\n                    <div style=\"text-align: center; margin-bottom: 15px; color: #5c6c7f; font-weight: bold;\">حجم الأسرة</div>\r\n                    \r\n                    <div class=\"checkbox-group\">\r\n                        <label class=\"checkbox-custom\">\r\n                            <input type=\"radio\" {% if doc.size_family == 'أسرة حديثة متكونة من زوجين' %}checked{% endif %}> أسرة حديثة متكونة من زوجين\r\n                        </label>\r\n                        <label class=\"checkbox-custom\">\r\n                            <input type=\"radio\" {% if doc.size_family == 'أسرة حديثة متكونة من زوجين وأطفال' %}checked{% endif %}> أسرة حديثة متكونة من زوجين وأطفال\r\n                        </label>\r\n                        <label class=\"checkbox-custom\">\r\n                            <input type=\"radio\" {% if doc.size_family == 'أسرة متكونة من زوجين وأبناء' %}checked{% endif %}> أسرة متكونة من زوجين وأبناء\r\n                        </label>\r\n                        <label class=\"checkbox-custom\">\r\n                            <input type=\"radio\" {% if doc.size_family == 'عائلة متكونة من زوجين وأبناء وأحفاد' %}checked{% endif %}> عائلة متكونة من زوجين وأبناء وأحفاد\r\n                        </label>\r\n                    </div>\r\n\r\n                    <hr style=\"border-top: 1px dashed #ccc; margin: 15px 0;\">\r\n                    \r\n                    <div style=\"text-align: center; margin-bottom: 15px; color: #5c6c7f; font-weight: bold;\">كم عدد أفراد مستخدمي المبنى من:</div>\r\n                    <div class=\"grid-2-cols\">\r\n                        <div class=\"form-row-custom\">\r\n                            <label>أزواج:</label>\r\n                            <div class=\"val-text\" style=\"text-align: center;\">{{ doc.couples or '0' }}</div>\r\n                        </div>\r\n                        <div class=\"form-row-custom\">\r\n                            <label>أحفاد:</label>\r\n                            <div class=\"val-text\" style=\"text-align: center;\">{{ doc.grandchildren or '0' }}</div>\r\n                        </div>\r\n                        <div class=\"form-row-custom\">\r\n                            <label>أولاد (أصغر من 10):</label>\r\n                            <div class=\"val-text\" style=\"text-align: center;\">{{ doc.boys_under_10 or '0' }}</div>\r\n                        </div>\r\n                        <div class=\"form-row-custom\">\r\n                            <label>بنات (أصغر من 10):</label>\r\n                            <div class=\"val-text\" style=\"text-align: center;\">{{ doc.girls_under_10 or '0' }}</div>\r\n                        </div>\r\n                        <div class=\"form-row-custom\">\r\n                            <label>أولاد (أكبر من 14):</label>\r\n                            <div class=\"val-text\" style=\"text-align: center;\">{{ doc.boys_above_14 or '0' }}</div>\r\n                        </div>\r\n                        <div class=\"form-row-custom\">\r\n                            <label>بنات (أكبر من 14):</label>\r\n                            <div class=\"val-text\" style=\"text-align: center;\">{{ doc.girls_above_14 or '0' }}</div>\r\n                        </div>\r\n                    </div>\r\n\r\n                    <hr style=\"border-top: 1px dashed #ccc; margin: 15px 0;\">\r\n\r\n                    <div style=\"margin-bottom: 15px; color: #5c6c7f; font-weight: bold;\">نمط الحياة و الخصوصية:</div>\r\n                    <div class=\"checkbox-group\">\r\n                        <label class=\"checkbox-custom\">\r\n                            <input type=\"radio\" {% if doc.haya == 'اجتماعي جداً' %}checked{% endif %}> اجتماعي جداً (احتمال وجود حركة زوار شبه دائمة)\r\n                        </label>\r\n                        <label class=\"checkbox-custom\">\r\n                            <input type=\"radio\" {% if doc.haya == 'اجتماعي' %}checked{% endif %}> اجتماعي (احتمالية وجود عدد زيارات قليلة)\r\n                        </label>\r\n                        <label class=\"checkbox-custom\">\r\n                            <input type=\"radio\" {% if doc.haya == 'غير اجتماعي' %}checked{% endif %}> غير اجتماعي (وجود زيارات في المناسبات فقط)\r\n                        </label>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n\r\n        <div>\r\n            <div class=\"survey-section\">\r\n                <div class=\"section-title\" style=\"float: right; border-radius: 0 8px 0 0;\">معلومات التواصل</div>\r\n                <div style=\"clear: both;\"></div>\r\n                <div class=\"section-content\">\r\n                    <div class=\"form-row-custom\">\r\n                        <label>الإسم:</label>\r\n                        <div class=\"val-text\">{{ doc.full_name or '' }}</div>\r\n                    </div>\r\n                    <div class=\"form-row-custom\">\r\n                        <label>رقم الهاتف:</label>\r\n                        <div class=\"val-text\" style=\"direction: ltr; text-align: right;\">{{ doc.phone or '' }}</div>\r\n                    </div>\r\n                    <div class=\"form-row-custom\">\r\n                        <label>البريد الإلكتروني:</label>\r\n                        <div class=\"val-text\">{{ doc.email or '' }}</div>\r\n                    </div>\r\n                    <div class=\"form-row-custom\">\r\n                        <label>مكان السكن الحالي:</label>\r\n                        <div class=\"val-text\">{{ doc.current_residence or '' }}</div>\r\n                    </div>\r\n                    <div class=\"form-row-custom\">\r\n                        <label>من أي مدينة:</label>\r\n                        <div class=\"val-text\">{{ doc.city or '' }}</div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n\r\n    </div>\r\n</div>",
